{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": "allow",
  "lsp": true,
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    // "openrtk"
    // "@tarquinen/opencode-dcp@latest"
  "@hueyexe/opencode-ensemble@0.15.0"
  ],
  "small_model": "mistral/mistral-vibe-cli-latest",
  "provider": {
    "bailian-token-plan": {
      "env": [
        "QWEN_CLOUD_API_KEY"
      ],
      "npm": "@ai-sdk/anthropic",
      "name": "Qwen Cloud",
      "options": {
        "baseURL": "https://token-plan.ap-southeast-1.maas.aliyuncs.com/apps/anthropic/v1",
        "apiKey": "{env:QWEN_CLOUD_API_KEY}"
      },
      "models": {
        "qwen3.7-max": {
          "name": "Qwen3.7 Max",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "qwen3.6-plus": {
          "name": "Qwen3.6 Plus",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "qwen3.6-flash": {
          "name": "Qwen3.6 Flash",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "deepseek-v3.2": {
          "name": "DeepSeek V3.2"
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "glm-5.2": {
          "name": "GLM-5.2",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        }
      }
    },
    "ollama-cloud-pay": {
      "id": "ollama-pay.thaigqsoft.com",
      "env": [
        "OLLAMA_PAY_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://ollama-pay.thaigqsoft.com/api/v1",
      "name": "ollama-pay.thaigqsoft.com",
      "models": {
        "deepseek-v4-pro:cloud": {
          "id": "deepseek-v4-pro:cloud",
          "name": "deepseek-v4-pro",
          "family": "deepseek-thinking",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "structured_output": true,
          "temperature": true,
          "knowledge": "2025-05",
          "release_date": "2026-04-24",
          "last_updated": "2026-04-24",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "open_weights": true,
          "cost": {
            "input": 1.74,
            "output": 3.48,
            "cache_read": 0.145
          },
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        }
      }
    },
    "maxplus-deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MaxPlus DeepSeek",
      "options": {
        "baseURL": "https://api.maxplus-ai.cc/deepseek/v1",
        "name": "maxplus-deepseek",
        "apiKey": "{env:MAXPLUS_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (MaxPlus)",
          "limit": {
            "context": 1048576,
            "output": 16384
          },
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (MaxPlus)",
          "limit": {
            "context": 1048576,
            "output": 16384
          },
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "minimax-m3": {
          "name": "MiniMax M3 (MaxPlus)",
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "glm-5.2": {
          "name": "GLM-5.2 (MaxPlus)",
          "limit": {
            "context": 204800,
            "output": 16384
          },
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1 (MaxPlus)",
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "reasoning": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        }
      }
    },
