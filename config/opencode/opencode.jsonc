{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": "allow",
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "small_model": "mistral/mistral-vibe-cli-latest",
  "provider": {
    "kimi-for-coding": {
      "npm": "@ai-sdk/anthropic",
      "name": "Kimi For Coding",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
        "apiKey": "{env:KIMI_API_KEY}"
      },
      "models": {
        "kimi-for-coding": {
          "name": "Kimi For Coding",
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    },
    "ollama-cloud": {
      "id": "ollama-cloud",
      "models": {
        "gemma4:31b": {
          "id": "gemma4:31b",
          "name": "gemma4:31b",
          "family": "gemma",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 131072
          }
        }
      }
    },
    "streamlake": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "StreamLake Coding Plan",
      "options": {
        "baseURL": "https://vanchin.streamlake.ai/api/gateway/coding/v1",
        "apiKey": "{env:VC_API_KEY}"
      },
      "models": {
        "kat-coder-pro-v1": {
          "name": "kat-coder-pro-v1"
        },
        "kat-coder-pro-v2": {
          "name": "kat-coder-pro-v2"
        }
      }
    },
    "mistral": {
      "id": "mistral",
      "models": {
        "mistral-vibe-cli-latest": {
          "name": "mistral-vibe-cli-latest",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "devstral-small-latest": {
          "name": "devstral-small-latest",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    },
    "synthetic": {
      "id": "synthetic",
      "env": [
        "SYNTHETIC_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://api.synthetic.new/v1",
      "name": "Synthetic",
      "models": {
        "hf:zai-org/GLM-4.7-Flash": {
          "id": "hf:zai-org/GLM-4.7-Flash",
          "name": "GLM-4.7-Flash",
          "family": "glm",
          "attachment": true,
          "tool_call": true,
          "temperature": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 0.06,
            "output": 0.4
          },
          "limit": {
            "context": 196608,
            "output": 8192
          }
        },
        "hf:zai-org/GLM-5": {
          "id": "hf:zai-org/GLM-5",
          "name": "GLM-5",
          "family": "glm",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "release_date": "2026-01-01",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1,
            "output": 6
          },
          "limit": {
            "context": 196608,
            "output": 65536
          }
        },
        "hf:zai-org/GLM-5.1": {
          "id": "hf:zai-org/GLM-5.1",
          "name": "GLM-5.1",
          "family": "glm",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "release_date": "2026-01-01",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1,
            "output": 6
          },
          "limit": {
            "context": 196608,
            "output": 65536
          }
        },
        "hf:nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4": {
          "id": "hf:nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4",
          "name": "nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4",
          "family": "nvidia",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "release_date": "2025-11-08",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 0.6,
            "output": 3
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "byteplus": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "byteplus",
      "options": {
        "baseURL": "https://ark.ap-southeast.bytepluses.com/api/coding/v3",
        "apiKey": "{env:ARK_API_KEY}"
      },
      "models": {
        "bytedance-seed-code": {
          "name": "bytedance-seed-code"
        },
        "kimi-k2.5": {
          "name": "kimi-k2.5"
        },
        "glm-4.7": {
          "name": "glm-4.7"
        },
        "kimi-k2-thinking": {
          "name": "kimi-k2-thinking"
        },
        "gpt-oss-120b": {
          "name": "gpt-oss-120b"
        }
      }
    }
  },
  "mcp": {
    // "openmemory": {
    //   "type": "remote",
    //   "url": "{env:OPENMEMORY_API_URL}",
    //   "headers": {
    //     "Authorization": "Bearer {env:OPENMEMORY_API_KEY}"
    //   }
    // },
    // "vibe_kanban": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "-y",
    //     "vibe-kanban@latest",
    //     "--mcp"
    //   ]
    // }
  },
  "agent": {
    "builder": {
      "mode": "subagent",
      // "model": "streamlake/kat-coder-pro-v2",
      "description": "Plan-based implementation specialist. Reads plans from .context/plans/, implements features step-by-step, updates plan timestamps, and creates implementation reports when obstacles occur. Use proactively when a plan exists and needs implementation.",
      "prompt": "{file:~/.dotfiles/agents/skills/builder/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "grep": true,
        "glob": true
      }
    },
    "reviewer": {
      "mode": "subagent",
      // "model": "synthetic/hf:zai-org/GLM-5",
      "description": "Implementation review specialist. Reads plans and implementation reports, verifies builder's work against plans, creates review reports with verdicts (PASS/PARTIAL/FAIL), and updates plan timestamps. Use proactively after builder completes implementation.",
      "prompt": "{file:~/.dotfiles/agents/skills/reviewer/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true,
        "grep": true,
        "glob": true
      }
    }
  }
}
