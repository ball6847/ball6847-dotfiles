{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": "allow",
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    // "@tarquinen/opencode-dcp@latest"
  ],
  "small_model": "mistral/mistral-vibe-cli-latest",
  "provider": {
