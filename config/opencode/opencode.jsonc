    "mistral": {
      "id": "mistral",
      "models": {
        "mistral-vibe-cli-latest": {
          "id": "mistral-vibe-cli-latest",
          "name": "mistral-vibe-cli-latest",
          "family": "mistral-medium",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "structured_output": true,
          "temperature": true,
          "release_date": "2026-04-29",
          "last_updated": "2026-04-29",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "open_weights": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "devstral-small-latest": {
          "id": "devstral-small-latest",
          "name": "devstral-small-latest",
          "family": "devstral",
          "attachment": false,
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "knowledge": "2025-05",
          "release_date": "2025-07-10",
          "last_updated": "2025-07-10",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "open_weights": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    },
    "synthetic": {
      "id": "synthetic",
      "env": [
        "SYNTHETIC_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://api.synthetic.new/v1",
      "name": "Synthetic",
      "models": {}

    }
  },
  "mcp": {
    // "openmemory": {
    //   "type": "remote",
    //   "url": "{env:OPENMEMORY_API_URL}",
    //   "headers": {
    //     "Authorization": "Bearer {env:OPENMEMORY_API_KEY}"
    //   }
    // },
    // "vibe_kanban": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "-y",
    //     "vibe-kanban@latest",
    //     "--mcp"
    //   ]
    // }
  },
  "agent": {
    "builder": {
      "mode": "subagent",
      // "model": "streamlake/kat-coder-pro-v2",
      "description": "Plan-based implementation specialist. Reads plans from .context/plans/, implements features step-by-step, updates plan timestamps, and creates implementation reports when obstacles occur. Use proactively when a plan exists and needs implementation.",
      "prompt": "{file:~/.dotfiles/agents/skills/builder/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "grep": true,
        "glob": true
      }
    },
    "reviewer": {
      "mode": "subagent",
      // "model": "synthetic/hf:zai-org/GLM-5",
      "description": "Implementation review specialist. Reads plans and implementation reports, verifies builder's work against plans, creates review reports with verdicts (PASS/PARTIAL/FAIL), and updates plan timestamps. Use proactively after builder completes implementation.",
      "prompt": "{file:~/.dotfiles/agents/skills/reviewer/SKILL.md}",
      "tools": {
        "read": true,
        "write": true,
        "bash": true,
        "grep": true,
        "glob": true
      }
    }
  }
}
