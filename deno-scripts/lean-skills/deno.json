{
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.4",
    "neverthrow": "npm:neverthrow@7"
  },
  "tasks": {
    "run": "deno run --allow-read --allow-write --allow-env main.ts",
    "check": "deno run --allow-read --allow-write --allow-env main.ts check",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "typecheck": "deno check main.ts"
  }
}
