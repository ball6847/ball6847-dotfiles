#!/bin/bash
#
# Setup agent skills symlinks
# 
# Many AI agents don't support the standard ~/.agents/skills directory.
# This script links each agent's skills directory to the shared ~/.agents/skills
# location, allowing skills to be managed in one place.
#
# Supported agents: kimi, vibe, claude
#

set -e

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_SOURCE="${DOTFILES_DIR}/agents/skills"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Ensure source skills directory exists
if [[ ! -d "$SKILLS_SOURCE" ]]; then
    log_error "Skills source directory not found: $SKILLS_SOURCE"
    exit 1
fi

# Define agent configurations
# Format: "agent_name:skills_subdir:relative_path_from_home"
declare -a AGENT_CONFIGS=(
    "kimi:skills:~/.kimi/skills"
    "vibe:skills:~/.vibe/skills"
    "vibe:agents:~/.vibe/agents"
    "vibe:prompts:~/.vibe/prompts"
    "claude:skills:~/.claude/skills"
)

link_agent_config() {
    local agent_name="$1"
    local config_type="$2"  # skills, agents, prompts, etc.
    local agent_config_path="$3"
    
    # Expand ~ to $HOME
    agent_config_path="${agent_config_path/#\~/$HOME}"
    local agent_dir="$(dirname "$agent_config_path")"
    
    # Determine source based on config type
    local source_path
    if [[ "$config_type" == "skills" ]]; then
        source_path="$SKILLS_SOURCE"
    else
        source_path="${DOTFILES_DIR}/config/${agent_name}/${config_type}"
        if [[ ! -d "$source_path" ]]; then
            log_warn "  Source directory not found: $source_path"
            return 0
        fi
    fi
    
    log_info "Setting up $agent_name $config_type..."
    
    # Check if agent directory exists
    if [[ ! -d "$agent_dir" ]]; then
        log_warn "$agent_name directory not found: $agent_dir"
        log_info "  Creating $agent_dir for future use..."
        mkdir -p "$agent_dir"
    fi
    
    # Handle existing config directory/link
    if [[ -e "$agent_config_path" ]]; then
        if [[ -L "$agent_config_path" ]]; then
            # It's already a symlink, check if it points to the right place
            local current_target
            current_target="$(readlink "$agent_config_path")"
            if [[ "$current_target" == "$source_path" ]]; then
                log_info "  $agent_name $config_type already correctly linked ✓"
                return 0
            else
                log_warn "  $agent_name $config_type linked to different location: $current_target"
                log_info "  Re-linking to $source_path..."
                rm "$agent_config_path"
            fi
        elif [[ -d "$agent_config_path" ]]; then
            # It's a regular directory - back it up
            local backup_path="${agent_config_path}.backup.$(date +%Y%m%d%H%M%S)"
            log_warn "  Found existing $agent_name $config_type directory"
            log_info "  Backing up to: $backup_path"
            mv "$agent_config_path" "$backup_path"
        else
            # It's a file or something else
            log_warn "  Found existing file at $agent_config_path, removing..."
            rm "$agent_config_path"
        fi
    fi
    
    # Create the symlink
    ln -sf "$source_path" "$agent_config_path"
    log_info "  Linked $agent_config_path → $source_path ✓"
}

# Main execution
main() {
    log_info "Setting up agent config symlinks..."
    log_info "Skills source: $SKILLS_SOURCE"
    echo ""
    
    local configured_count=0
    
    for config in "${AGENT_CONFIGS[@]}"; do
        IFS=':' read -r agent_name config_type agent_config_path <<< "$config"
        link_agent_config "$agent_name" "$config_type" "$agent_config_path"
        configured_count=$((configured_count + 1))
        echo ""
    done
    
    log_info "Done! Configured $configured_count agent config(s)."
    log_info ""
    log_info "Note: Agent runtime data (kimi.json, credentials, logs, etc.) remain in ~"
    log_info "      Only shared configs (skills, agents, prompts) are linked to dotfiles."
}

# Allow sourcing this script for functions, or direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
